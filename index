<!DOCTYPE html>
<html lang="pt-BR">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>Recarga Fácil MTU — Baixar App</title>
  <style>
    @import url('https://fonts.googleapis.com/css2?family=Sora:wght@400;600;700&display=swap');

    :root {
      --green: #1D9E75;
      --green-dark: #0F6E56;
      --green-light: #E1F5EE;
      --green-mid: #9FE1CB;
      --text: #1a1a1a;
      --muted: #5a5a5a;
      --bg: #f7faf9;
    }

    * { box-sizing: border-box; margin: 0; padding: 0; }

    body {
      font-family: 'Sora', sans-serif;
      background: var(--bg);
      min-height: 100vh;
      display: flex;
      flex-direction: column;
      align-items: center;
      justify-content: center;
      padding: 2rem 1rem;
    }

    .card {
      background: #fff;
      border-radius: 24px;
      padding: 2.5rem 2rem;
      max-width: 400px;
      width: 100%;
      box-shadow: 0 4px 32px rgba(0,0,0,0.08);
      text-align: center;
    }

    .logo-wrap {
      width: 80px;
      height: 80px;
      background: var(--green-light);
      border-radius: 20px;
      display: flex;
      align-items: center;
      justify-content: center;
      margin: 0 auto 1.25rem;
    }

    .logo-wrap svg {
      width: 44px;
      height: 44px;
    }

    h1 {
      font-size: 1.5rem;
      font-weight: 700;
      color: var(--text);
      margin-bottom: 0.4rem;
    }

    .subtitle {
      font-size: 0.9rem;
      color: var(--muted);
      margin-bottom: 2rem;
    }

    .btn {
      display: flex;
      align-items: center;
      gap: 14px;
      width: 100%;
      padding: 1rem 1.25rem;
      border-radius: 14px;
      text-decoration: none;
      font-family: 'Sora', sans-serif;
      font-size: 0.95rem;
      font-weight: 600;
      margin-bottom: 0.875rem;
      transition: transform 0.15s, box-shadow 0.15s;
      border: none;
      cursor: pointer;
    }

    .btn:last-child { margin-bottom: 0; }

    .btn:active { transform: scale(0.98); }

    .btn-android {
      background: var(--green);
      color: #fff;
    }

    .btn-android:hover { background: var(--green-dark); box-shadow: 0 4px 16px rgba(29,158,117,0.35); }

    .btn-ios {
      background: #1a1a1a;
      color: #fff;
    }

    .btn-ios:hover { background: #333; box-shadow: 0 4px 16px rgba(0,0,0,0.2); }

    .btn-icon {
      width: 36px;
      height: 36px;
      flex-shrink: 0;
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .btn-text { text-align: left; }
    .btn-label { font-size: 0.72rem; font-weight: 400; opacity: 0.8; display: block; }
    .btn-name { font-size: 1rem; font-weight: 700; display: block; }

    .divider {
      font-size: 0.75rem;
      color: var(--muted);
      margin: 1.5rem 0;
      display: flex;
      align-items: center;
      gap: 10px;
    }

    .divider::before, .divider::after {
      content: '';
      flex: 1;
      height: 1px;
      background: #e0e0e0;
    }

    .redirect-note {
      font-size: 0.75rem;
      color: var(--muted);
      margin-top: 1.5rem;
    }

    #auto-msg {
      display: none;
      background: var(--green-light);
      color: var(--green-dark);
      border-radius: 10px;
      padding: 0.75rem 1rem;
      font-size: 0.82rem;
      font-weight: 600;
      margin-bottom: 1.5rem;
    }
  </style>
</head>
<body>

<div class="card">

  <div class="logo-wrap">
    <svg viewBox="0 0 44 44" fill="none" xmlns="http://www.w3.org/2000/svg">
      <rect width="44" height="44" rx="12" fill="#1D9E75"/>
      <path d="M13 22C13 17.03 17.03 13 22 13C26.97 13 31 17.03 31 22C31 26.97 26.97 31 22 31" stroke="white" stroke-width="2.5" stroke-linecap="round"/>
      <path d="M22 18V22L25 25" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
      <path d="M14 28L14 31L17 31" stroke="white" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
    </svg>
  </div>

  <h1>Recarga Fácil MTU</h1>
  <p class="subtitle">Escolha sua loja para baixar o aplicativo</p>

  <div id="auto-msg"></div>

  <a class="btn btn-android" id="btn-android"
     href="https://play.google.com/store/apps/details?id=com.simpleway.RecargaFacil&hl=pt">
    <div class="btn-icon">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="white">
        <path d="M3.18 23a1 1 0 0 1-.87-1.5l7.5-13a1 1 0 0 1 1.74 0l7.5 13A1 1 0 0 1 18.18 23H3.18zM14.5 2.27l-2-3.46a.5.5 0 0 0-.87 0l-2 3.46A8 8 0 0 1 14.5 2.27zM21 7H3a1 1 0 0 0-.95 1.32l2 6A1 1 0 0 0 5 15h14a1 1 0 0 0 .95-.68l2-6A1 1 0 0 0 21 7z"/>
      </svg>
    </div>
    <div class="btn-text">
      <span class="btn-label">Disponível no</span>
      <span class="btn-name">Google Play</span>
    </div>
  </a>

  <a class="btn btn-ios" id="btn-ios"
     href="https://apps.apple.com/br/app/recarga-f%C3%A1cil-mtu/id1471260228">
    <div class="btn-icon">
      <svg width="22" height="22" viewBox="0 0 22 22" fill="white">
        <path d="M16.08 11.53c-.03-3.04 2.48-4.52 2.6-4.59-1.42-2.08-3.62-2.36-4.4-2.39-1.87-.19-3.65 1.1-4.6 1.1-.95 0-2.42-1.07-3.97-1.04C3.66 4.65 1.9 5.74.97 7.47c-1.87 3.22-.48 8.01 1.35 10.63.9 1.29 1.97 2.73 3.37 2.68 1.36-.06 1.87-.88 3.51-.88 1.64 0 2.1.88 3.53.85 1.46-.03 2.38-1.31 3.28-2.61.99-1.47 1.4-2.88 1.43-2.96-.03-.01-2.73-1.05-2.76-4.15zM13.33 3c.74-.92 1.25-2.17 1.11-3.44-1.07.04-2.4.72-3.17 1.62-.69.79-1.3 2.07-1.14 3.29 1.2.09 2.42-.61 3.2-1.47z"/>
      </svg>
    </div>
    <div class="btn-text">
      <span class="btn-label">Disponível na</span>
      <span class="btn-name">App Store</span>
    </div>
  </a>

  <p class="redirect-note">O sistema detecta seu dispositivo e redireciona automaticamente</p>

</div>

<script>
  var ua = navigator.userAgent || '';
  var isIOS = /iPad|iPhone|iPod/.test(ua) && !window.MSStream;
  var isAndroid = /Android/.test(ua);
  var msg = document.getElementById('auto-msg');

  if (isIOS) {
    msg.style.display = 'block';
    msg.textContent = 'iPhone detectado — redirecionando para a App Store...';
    setTimeout(function() {
      window.location.href = 'https://apps.apple.com/br/app/recarga-f%C3%A1cil-mtu/id1471260228';
    }, 1800);
  } else if (isAndroid) {
    msg.style.display = 'block';
    msg.textContent = 'Android detectado — redirecionando para o Google Play...';
    setTimeout(function() {
      window.location.href = 'https://play.google.com/store/apps/details?id=com.simpleway.RecargaFacil&hl=pt';
    }, 1800);
  }
</script>

</body>
</html>
